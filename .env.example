# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TEMPERATURE=0.3

# Redis (shared with Pitcore, using db=1)
REDIS_URL=redis://localhost:6379/1

# UAZAPI (WhatsApp)
UAZAPI_BASE_URL=https://pitcore.uazapi.com
UAZAPI_TOKEN=your-uazapi-token-here

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
LOG_LEVEL=info

# CORS (comma-separated origins)
CORS_ORIGINS=https://pitcore.online,http://localhost:3000

# Conversation
CONVERSATION_TTL_HOURS=24

# Escalation (WhatsApp number for human handoff)
ESCALATION_WHATSAPP=5511999999999
ESCALATION_NOTIFY_EMAIL=contato@pitcore.com.br
