# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# Redis (shared with Pitcore, using db=1)
REDIS_URL=redis://localhost:6379/1

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=pitcore-whatsapp

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
LOG_LEVEL=info

# CORS (comma-separated origins)
CORS_ORIGINS=https://pitcore.online,http://localhost:3000

# Conversation
CONVERSATION_TTL_HOURS=24

# Escalation (WhatsApp number for human handoff)
ESCALATION_WHATSAPP=5511999999999
ESCALATION_NOTIFY_EMAIL=contato@pitcore.com.br
